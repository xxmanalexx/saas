generator client {
  provider   = "prisma-client-js"
  engineType = "client"
  output   = "../node_modules/.prisma/client/sqlite"
}

datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? 
  access_token      String? 
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? 
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Business Models ────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    DateTime?
  image            String?
  hashedPassword   String?
  stripeCustomerId String?   @unique
  plan             Plan      @default(FREE)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  workspaces  Workspace[]
}

enum Plan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  userId    String
  settings  Json     @default("{}")
  // Ollama AI config
  ollamaUrl    String   @default("http://localhost:11434")
  ollamaModel  String   @default("llama3.2")
  // Whether to allow extended thinking (default true — set false to disable)
  ollamaThinking Boolean @default(true)
  // Optional custom database connection string (overrides env DATABASE_URL)
  databaseUrl  String?  @default("")

  // Database provider: "postgresql" (Neon/remote) or "sqlite" (local zero-setup)
  databaseProvider String @default("postgresql")

  // Follow-up config
  followUpEnabled       Boolean @default(false)
  followUpDelayMinutes  Int     @default(300) // 5 hours after last customer message
  followUpInstructions  String  @default("")
  followUpMessage       String  @default("") // the actual follow-up message template
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  agents         Agent[]
  conversations  Conversation[]
  contacts       Contact[]
  leads          Lead[]
  flows          Flow[]
  integrations   Integration[]
  transcripts    Transcript[]
  knowledgeBase  KnowledgeBase[]
  personas       AgentPersona[]
}

model Agent {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  type        AgentType
  config      Json     @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages  AgentMessage[]
  logs      AgentLog[]
}

enum AgentType {
  ROUTER
  LEAD_QUALIFICATION
  BOOKING
  SUPPORT
  FOLLOW_UP
}

// ─── Conversation & Messaging ────────────────────────────────────────────────

model Conversation {
  id           String            @id @default(cuid())
  workspaceId  String
  channel      Channel
  channelId    String            // WhatsApp message ID, IG recipient, web chat session ID, etc.
  contactId    String?
  status       ConversationStatus @default(ACTIVE)
  assignedTo   String?           // human agent ID if escalated
  followUpSentAt DateTime?       // timestamp when auto follow-up was sent
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact  Contact?     @relation(fields: [contactId], references: [id])
  messages Message[]
  transcript Transcript?

  @@unique([workspaceId, channel, channelId])
}

enum Channel {
  WHATSAPP
  INSTAGRAM
  WEB_CHAT
  EMAIL
}

enum ConversationStatus {
  ACTIVE
  ESCALATED
  RESOLVED
  ABANDONED
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           Role
  content        String   
  metadata       Json     @default("{}")
  tokensUsed     Int?
  latencyMs      Int?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ASSISTANT
  SYSTEM
}

model AgentMessage {
  id        String   @id @default(cuid())
  agentId   String
  role      Role
  content   String   
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

// ─── Contacts & Leads ────────────────────────────────────────────────────────

model Contact {
  id                String   @id @default(cuid())
  workspaceId       String
  channel           Channel
  channelIdentifier String
  profile           Json     @default("{}") // name, avatar, etc.
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations  Conversation[]
  leads          Lead[]

  @@unique([workspaceId, channel, channelIdentifier])
}

model Lead {
  id          String     @id @default(cuid())
  workspaceId String
  contactId   String
  score       Int        @default(0) // 0-100
  stage       LeadStage  @default(NEW)
  ownerId     String?    // sales rep user ID
  notes       String?    
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact  Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  events   LeadEvent[]
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

model LeadEvent {
  id        String   @id @default(cuid())
  leadId    String
  type      String   // stage_change, note_added, email_sent, call_logged
  data      Json     @default("{}")
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

// ─── Flows ────────────────────────────────────────────────────────────────────

model Flow {
  id         String   @id @default(cuid())
  workspaceId String
  name       String
  trigger    String   // event that starts this flow (e.g. "new_lead", "keyword:pricing")
  nodes      Json     @default("[]") // array of FlowNode objects
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  runs      FlowRun[]
}

model FlowRun {
  id        String     @id @default(cuid())
  flowId    String
  contactId String
  status    FlowRunStatus @default(RUNNING)
  startedAt DateTime   @default(now())
  endedAt   DateTime?

  flow Flow @relation(fields: [flowId], references: [id], onDelete: Cascade)
}

enum FlowRunStatus {
  RUNNING
  COMPLETED
  FAILED
  ABANDONED
}

// ─── Integrations ─────────────────────────────────────────────────────────────

model Integration {
  id           String           @id @default(cuid())
  workspaceId  String
  channel      Channel
  credentials  Json             @default("{}") // encrypted
  status       IntegrationStatus @default(DISCONNECTED)
  settings     Json             @default("{}")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, channel])
}

enum IntegrationStatus {
  DISCONNECTED
  CONNECTED
  ERROR
  RATE_LIMITED
}

// ─── Logs (append-only) ────────────────────────────────────────────────────────

model Transcript {
  id             String   @id @default(cuid())
  workspaceId    String
  conversationId String   @unique
  messages       Json     @default("[]")
  createdAt      DateTime @default(now())

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model AgentLog {
  id        String   @id @default(cuid())
  agentId   String
  input     Json
  output    Json
  tokens    Int?
  latencyMs Int?
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

// ─── Knowledge Base ────────────────────────────────────────────────────────────

model KnowledgeBase {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  content     String   
  category    String   @default("general") // general, faq, pricing, policy, product
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── Agent Persona ─────────────────────────────────────────────────────────────

model AgentPersona {
  id          String      @id @default(cuid())
  workspaceId String
  name        String
  role        PersonaRole @default(SUPPORT)
  tone        PersonaTone @default(FRIENDLY)
  language    String      @default("en") // en, ar, hi, fr, etc.
  dialect     String      @default("")   // khaliji, iraqi, shami, egyptian, maghrebi, saudi, or empty
  emojiStyle  EmojiStyle  @default(SOMETIMES)
  instructions String     @default("")
  isDefault   Boolean     @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

enum PersonaRole {
  RECEPTIONIST
  MARKETER
  SALES
  SUPPORT
  GENERAL
}

enum PersonaTone {
  FRIENDLY
  PROFESSIONAL
  CASUAL
  FORMAL
}

enum EmojiStyle {
  NEVER
  SOMETIMES
  OFTEN
}
